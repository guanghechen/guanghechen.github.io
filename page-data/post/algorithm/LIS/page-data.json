{"componentChunkName":"component---src-layout-blog-post-index-tsx","path":"/post/algorithm/LIS/","result":{"data":{"content":{"title":"最长上升子序列（LIS）","description":"最长上升子序列（LIS）","createAt":"June 02, 2021","updateAt":"June 02, 2021","timeToRead":"5min 17s","frontmatter2":{"aplayer":null,"wechatThumbnail":null},"toc":{"children":[{"depth":2,"identifier":"heading-算法一","contents":[{"type":"text","value":"算法一"}],"children":[{"depth":3,"identifier":"heading-找到-lis-的长度","contents":[{"type":"text","value":"找到 LIS 的长度"}],"children":[]},{"depth":3,"identifier":"heading-找到字典序最小的-lis","contents":[{"type":"text","value":"找到字典序最小的 LIS"}],"children":[]},{"depth":3,"identifier":"heading-复杂度分析","contents":[{"type":"text","value":"复杂度分析"}],"children":[]}]},{"depth":2,"identifier":"heading-算法二","contents":[{"type":"text","value":"算法二"}],"children":[{"depth":3,"identifier":"heading-找到-lis-的长度-2","contents":[{"type":"text","value":"找到 LIS 的长度"}],"children":[]},{"depth":3,"identifier":"heading-找到字典序最小的-lis-2","contents":[{"type":"text","value":"找到字典序最小的 LIS"}],"children":[]},{"depth":3,"identifier":"heading-复杂度分析-2","contents":[{"type":"text","value":"复杂度分析"}],"children":[]}]},{"depth":2,"identifier":"heading-扩展","contents":[{"type":"text","value":"扩展"}],"children":[]},{"depth":2,"identifier":"heading-related","contents":[{"type":"text","value":"Related"}],"children":[]}]},"categories":[],"tags":["最长上升子序列","LIS"],"ast":{"type":"root","children":[{"type":"paragraph","children":[{"type":"text","value":"对于数列 "},{"type":"inlineMath","value":"A=\\lbrace a_1,a_2,\\cdots,a_N \\rbrace"},{"type":"text","value":"，其任一上升子序列\n"},{"type":"inlineMath","value":"B=\\lbrace a_{b_1}, a_{b_2}, \\cdots, a_{b_M}\\rbrace"},{"type":"text","value":" 满足\n"},{"type":"inlineMath","value":"b_i < b_{i+1}"},{"type":"text","value":" 且 "},{"type":"inlineMath","value":"a_{b_i} < a_{b_{i+1}}"},{"type":"text","value":"。"},{"type":"inlineMath","value":"A"},{"type":"text","value":" 的最长上升子序列指 "},{"type":"inlineMath","value":"A"},{"type":"text","value":" 的所有上升子序列中元素个数最多的那些。"}]},{"type":"paragraph","children":[{"type":"inlineMath","value":"A"},{"type":"text","value":" 的字典序最小的最长上升子序列指 "},{"type":"inlineMath","value":"A"},{"type":"text","value":" 的最长上升子序列中（不妨设元素个数为 "},{"type":"inlineMath","value":"M"},{"type":"text","value":"），元素下标组成的 "},{"type":"inlineMath","value":"M"},{"type":"text","value":" 维向量最小的那个。"}]},{"type":"heading","depth":2,"children":[{"type":"text","value":"算法一"}],"identifier":"heading-算法一"},{"type":"heading","depth":3,"children":[{"type":"text","value":"找到 LIS 的长度"}],"identifier":"heading-找到-lis-的长度"},{"type":"paragraph","children":[{"type":"text","value":"记 "},{"type":"inlineMath","value":"dp_{i}"},{"type":"text","value":" 表示前 "},{"type":"inlineMath","value":"i"},{"type":"text","value":" 个数中以第 "},{"type":"inlineMath","value":"i"},{"type":"text","value":" 个数结尾的最长上升子序列长度，则状态转移方程为："}]},{"type":"math","value":"dp_{i}=\\max \\lbrace dp_x | 1 \\leqslant x < i, a_x < a_{i} \\rbrace + 1"},{"type":"html","value":"<!-- more -->\n"},{"type":"code","lang":"typescript","meta":"title=\"lis-1-1.ts\" {6}","value":"function findLengthOfLIS(a: number[], N: number): number {\n  const dp: number[] = new Array(N).fill(1)\n  for (let i = 0; i < N; ++i) {\n    let x = 0\n    for (let j = 0; j < i; ++j) {\n      if (a[j] < a[i] && x < dp[j]) x = dp[j]\n    }\n    dp[i] = x + 1\n  }\n  return dp[N - 1]\n}\n"},{"type":"heading","depth":3,"children":[{"type":"text","value":"找到字典序最小的 LIS"}],"identifier":"heading-找到字典序最小的-lis"},{"type":"paragraph","children":[{"type":"text","value":"在完成上一步的运算后，维护一个数组 "},{"type":"inlineMath","value":"C=\\lbrace c_1, c_2, \\cdots, c_M\\rbrace"},{"type":"text","value":"，其中，"},{"type":"inlineMath","value":"c_i"},{"type":"text","value":" 表示长度为 "},{"type":"inlineMath","value":"i"},{"type":"text","value":" 的上升子序列的最后一个元素在 "},{"type":"inlineMath","value":"A"},{"type":"text","value":" 中的最小下标，则字典序最小的 LIS 为："},{"type":"inlineMath","value":"a_{c_1}, a_{c_2}, \\cdots, a_{c_M}"},{"type":"text","value":"。"}]},{"type":"paragraph","children":[{"type":"text","value":"维护这个数组的复杂度为 "},{"type":"inlineMath","value":"O(N)"},{"type":"text","value":"，扫描到 "},{"type":"inlineMath","value":"i"},{"type":"text","value":" 时，若此时 "},{"type":"inlineMath","value":"c_{dp_i}"},{"type":"text","value":" 还未设置值，则将 "},{"type":"inlineMath","value":"c_{dp_i}"},{"type":"text","value":" 设置成 "},{"type":"inlineMath","value":"i"},{"type":"text","value":"，否则忽略它:"}]},{"type":"code","lang":"typescript","meta":"title=\"lis-1-2.ts\" {3,10}","value":"function findMinimumLexicographicOrderLIS(a: number[], N: number): number[] {\n  const dp: number[] = new Array(N)\n  const c: number[] = new Array(N).fill(-1)\n  for (let i = 0; i < N; ++i) {\n    let x = 0\n    for (let j = 0; j < i; ++j) {\n      if (a[j] < a[i] && x < dp[j]) x = dp[j]\n    }\n    dp[i] = x + 1\n    if (c[x] === -1) c[x] = i\n  }\n  return c.slice(0, dp[N-1])\n}\n"},{"type":"heading","depth":3,"children":[{"type":"text","value":"复杂度分析"}],"identifier":"heading-复杂度分析"},{"type":"paragraph","children":[{"type":"text","value":"边界情况是找不到这样的 "},{"type":"inlineMath","value":"x"},{"type":"text","value":"，此时相当于 "},{"type":"inlineMath","value":"dp_i=1"},{"type":"text","value":"。不难发现，对于每个位置 "},{"type":"inlineMath","value":"i"},{"type":"text","value":"，需要扫描 "},{"type":"inlineMath","value":"i-1"},{"type":"text","value":" 个元素，因此"}]},{"type":"list","ordered":false,"marker":45,"spread":true,"children":[{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"时间复杂度："},{"type":"inlineMath","value":"\\displaystyle O\\left(\\sum_{i=1} ^ {N} (i - 1)\\right)=O(N^2)"}]}]},{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"空间复杂度："},{"type":"inlineMath","value":"O(N)"}]}]}]},{"type":"heading","depth":2,"children":[{"type":"text","value":"算法二"}],"identifier":"heading-算法二"},{"type":"heading","depth":3,"children":[{"type":"text","value":"找到 LIS 的长度"}],"identifier":"heading-找到-lis-的长度-2"},{"type":"paragraph","children":[{"type":"text","value":"维护一个单调栈 "},{"type":"inlineMath","value":"S"},{"type":"text","value":"，扫描数列 "},{"type":"inlineMath","value":"A"},{"type":"text","value":"，若 "},{"type":"inlineMath","value":"a_i"},{"type":"text","value":" 大于栈顶元素，则压栈，否则替换掉 "},{"type":"inlineMath","value":"S"},{"type":"text","value":"\n中第一个大于等于 "},{"type":"inlineMath","value":"a_i"},{"type":"text","value":" 的元素 "},{"type":"inlineMath","value":"S_x"},{"type":"text","value":"。则扫描完毕后，"},{"type":"inlineMath","value":"S"},{"type":"text","value":" 长度即为 "},{"type":"inlineMath","value":"A"},{"type":"text","value":" 的最长上升子序列的长度。因为 "},{"type":"inlineMath","value":"S"},{"type":"text","value":" 是单调栈，所以可以使用二分搜索 ("},{"type":"inlineCode","value":"lower_bound"},{"type":"text","value":") 快速找到 "},{"type":"inlineMath","value":"S_x"},{"type":"text","value":"。"}]},{"type":"code","lang":"typescript","meta":"title=\"lis-2-1.ts\" {5}","value":"function findLengthOfLIS(a: number[], N: number): number {\n  const s: number[] = [a[0]]\n  for (let i = 1; i < N; ++i) {\n    const y = a[i]\n    const x = lowerBound(0, s.length, x => s[x] < y)\n\n    // In Javascript / Typescript, the following condition can be omitted\n    if (x > s.length) s.push(y)\n    else s[x] = y\n  }\n  return s.length\n}\n"},{"type":"heading","depth":3,"children":[{"type":"text","value":"找到字典序最小的 LIS"}],"identifier":"heading-找到字典序最小的-lis-2"},{"type":"paragraph","children":[{"type":"text","value":"在上一步求出 "},{"type":"inlineMath","value":"x"},{"type":"text","value":" 时，实际上也求出了以位置 "},{"type":"inlineMath","value":"i"},{"type":"text","value":" 为结尾的最长 "},{"type":"inlineMath","value":"LIS"},{"type":"text","value":" 长度，即方法一中的 "},{"type":"inlineMath","value":"dp_i"},{"type":"text","value":"，故可复用方法一中求字典序最小的 LIS 算法。"}]},{"type":"code","lang":"typescript","meta":"title=\"lis-2-2.ts\" {3,11}","value":"function findMinimumLexicographicOrderLIS(a: number[], N: number): number[] {\n  const s: number[] = []\n  const c: number[] = new Array(N).fill(-1)\n  for (let i = 0; i < N; ++i) {\n    const y = a[i]\n    const x = lowerBound(0, s.length, x => s[x] < y)\n\n    // In fact, we don’t really need the dp array, as we only need to know \n    // the length of the LIS formed by the first (i+1) elements, and that \n    // value is (x+1).\n    if (c[x] === -1) c[x] = i\n\n    // In Javascript / Typescript, the following condition can be omitted\n    if (x > s.length) s.push(y)\n    else s[x] = y\n  }\n  return c.slice(0, s.length)\n}\n"},{"type":"heading","depth":3,"children":[{"type":"text","value":"复杂度分析"}],"identifier":"heading-复杂度分析-2"},{"type":"paragraph","children":[{"type":"text","value":"扫描数列复杂度为 "},{"type":"inlineMath","value":"O(N)"},{"type":"text","value":"，每扫描到一个位置时，通过 "},{"type":"inlineMath","value":"O(\\log N)"},{"type":"text","value":" 的二分搜索算法找到目标位置，故"}]},{"type":"list","ordered":false,"marker":45,"spread":false,"children":[{"type":"listItem","children":[{"type":"text","value":"时间复杂度："},{"type":"inlineMath","value":"O(N \\log N)"}]},{"type":"listItem","children":[{"type":"text","value":"空间复杂度："},{"type":"inlineMath","value":"O(N)"}]}]},{"type":"heading","depth":2,"children":[{"type":"text","value":"扩展"}],"identifier":"heading-扩展"},{"type":"paragraph","children":[{"type":"text","value":"上面提到的两个算法除了求 LCS 外，还都支持求 "},{"type":"emphasis","children":[{"type":"strong","children":[{"type":"text","value":"最长非严格单调递增子序列"}]}]},{"type":"text","value":"。"}]},{"type":"list","ordered":false,"marker":42,"spread":true,"children":[{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"算法一（"},{"type":"inlineMath","value":"O(N^2)"},{"type":"text","value":"），只要把转移方程改成如下形式就好了："}]},{"type":"math","value":"dp_{i}=\\max \\lbrace dp_x | 1 \\leqslant x < i, a_x \\leqslant a_{i} \\rbrace + 1"}]},{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"算法二（"},{"type":"inlineMath","value":"O(N\\log N)"},{"type":"text","value":"），只要在计算 "},{"type":"inlineCode","value":"lowerBound"},{"type":"text","value":" 时，把 "},{"type":"inlineCode","value":"s[x] < y"},{"type":"text","value":" 改成 "},{"type":"inlineCode","value":"s[x] <= y"},{"type":"text","value":" 就好了："}]},{"type":"code","lang":"typescript","meta":"title=\"lis-2-3.ts\" {5}","value":"function findLengthOfLIS(a: number[], N: number): number {\n  const s: number[] = [a[0]]\n  for (let i = 1; i < N; ++i) {\n    const y = a[i]\n    const x = lowerBound(0, s.length, x => s[x] <= y)\n\n    // In Javascript / Typescript, the following condition can be omitted\n    if (x > s.length) s.push(y)\n    else s[x] = y\n  }\n  return s.length\n}\n"}]}]},{"type":"heading","depth":2,"children":[{"type":"text","value":"Related"}],"identifier":"heading-related"},{"type":"list","ordered":false,"marker":42,"spread":false,"children":[{"type":"listItem","children":[{"type":"link","url":"../LCS","children":[{"type":"text","value":"最长公共子序列（LCS） | guanghechen"}]}]},{"type":"listItem","children":[{"type":"link","url":"https://leetcode.com/problems/longest-increasing-subsequence/","children":[{"type":"text","value":"#300. Longest Increasing Subsequence | Leetcode"}]}]}]}]},"ecmaImports":[],"definitionMap":{},"footnoteDefinitionMap":{},"fields":{"slug":"/post/algorithm/LIS/"}},"previous":{"title":"Dijkstra 算法","fields":{"slug":"/post/algorithm/graph/shortest-path/dijkstra/"}},"next":{"title":"最长公共子序列（LCS）","fields":{"slug":"/post/algorithm/LCS/"}},"postItems":{"nodes":[{"title":"最长公共子序列（LCS）","createAt":"2021-06-02","tags":["最长公共子序列","LCS"],"fields":{"slug":"/post/algorithm/LCS/"}},{"title":"最长上升子序列（LIS）","createAt":"2021-06-02","tags":["最长上升子序列","LIS"],"fields":{"slug":"/post/algorithm/LIS/"}},{"title":"洗牌问题和 knuth-shuffle 算法","createAt":"2021-07-22","tags":["shuffle","knuth-shuffle","约瑟夫环"],"fields":{"slug":"/post/algorithm/shuffle/"}},{"title":"编译原理-语法制导翻译实现计算器","createAt":"2016-06-23","tags":["编译原理","语法制导翻译","计算机"],"fields":{"slug":"/post/fundamentals-of-compiling/exercise/"}},{"title":"编译原理-语法分析