uad \\mathsf{FOLLOW}(D) = \\Big\\lbrace \\$,),*,\\div,+,- \\Big\\rbrace\\\\\n    \\mathsf{FIRST}(E) = \\Big\\lbrace *,\\div,\\varepsilon \\Big\\rbrace &\\quad \\mathsf{FOLLOW}(E) = \\Big\\lbrace \\$,),+,- \\Big\\rbrace\\\\\n  \\end{aligned}\n"},{"type":"heading","depth":3,"children":[{"type":"text","value":"LL(1) 预测分析表"}],"identifier":"heading-ll-1-预测分析表"},{"type":"table","columns":[{"align":"center"},{"align":"center"},{"align":"center"},{"align":"center"},{"align":"center"},{"align":"center"},{"align":"center"},{"align":"center"},{"align":"center"}],"children":[{"type":"tableRow","children":[{"type":"tableCell","children":[{"type":"text","value":"Token"}]},{"type":"tableCell","children":[{"type":"text","value":"Digit"}]},{"type":"tableCell","children":[{"type":"inlineMath","value":"("}]},{"type":"tableCell","children":[{"type":"inlineMath","value":")"}]},{"type":"tableCell","children":[{"type":"inlineMath","value":"+"}]},{"type":"tableCell","children":[{"type":"inlineMath","value":"-"}]},{"type":"tableCell","children":[{"type":"inlineMath","value":"*"}]},{"type":"tableCell","children":[{"type":"inlineMath","value":"\\div"}]},{"type":"tableCell","children":[{"type":"inlineMath","value":"\\$"}]}]},{"type":"tableRow","children":[{"type":"tableCell","children":[{"type":"inlineMath","value":"A"}]},{"type":"tableCell","children":[{"type":"inlineMath","value":"A \\rightarrow BC"}]},{"type":"tableCell","children":[{"type":"inlineMath","value":"A \\rightarrow BC"}]},{"type":"tableCell","children":[]},{"type":"tableCell","children":[]},{"type":"tableCell","children":[]},{"type":"tableCell","children":[]},{"type":"tableCell","children":[]},{"type":"tableCell","children":[]}]},{"type":"tableRow","children":[{"type":"tableCell","children":[{"type":"inlineMath","value":"B"}]},{"type":"tableCell","children":[{"type":"inlineMath","value":"B \\rightarrow DE"}]},{"type":"tableCell","children":[{"type":"inlineMath","value":"B \\rightarrow DE"}]},{"type":"tableCell","children":[]},{"