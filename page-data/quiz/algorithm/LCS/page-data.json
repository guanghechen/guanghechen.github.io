{"componentChunkName":"component---src-layout-blog-post-index-tsx","path":"/quiz/algorithm/LCS/","result":{"data":{"content":{"title":"最长公共子序列（LCS）","description":"最长公共子序列（LCS）","createAt":"June 02, 2021","updateAt":"June 02, 2021","timeToRead":"2min 54s","frontmatter2":{"aplayer":null,"wechatThumbnail":null},"toc":{"children":[{"depth":2,"identifier":"heading-算法一","contents":[{"type":"text","value":"算法一"}],"children":[]},{"depth":2,"identifier":"heading-算法二","contents":[{"type":"text","value":"算法二"}],"children":[]},{"depth":2,"identifier":"heading-related","contents":[{"type":"text","value":"Related"}],"children":[]}]},"categories":[],"tags":["quiz","最长公共子序列","LCS"],"ast":{"type":"root","children":[{"type":"paragraph","children":[{"type":"text","value":"对于数列 "},{"type":"inlineMath","value":"A=\\lbrace a_1,a_2,\\cdots,a_M \\rbrace"},{"type":"text","value":" 和数列 "},{"type":"inlineMath","value":"B=\\lbrace b_1,b_2,\\cdots,b_N \\rbrace"},{"type":"text","value":"，若 "},{"type":"inlineMath","value":"C=\\lbrace c_1,c_2,\\cdots,c_K \\rbrace"},{"type":"text","value":" 既是 "},{"type":"inlineMath","value":"A"},{"type":"text","value":" 的子序列，又是 "},{"type":"inlineMath","value":"B"},{"type":"text","value":" 的子序列，则称 "},{"type":"inlineMath","value":"C"},{"type":"text","value":" 是 "},{"type":"inlineMath","value":"A"},{"type":"text","value":" 和 "},{"type":"inlineMath","value":"B"},{"type":"text","value":" 的公共子序列。"},{"type":"inlineMath","value":"A"},{"type":"text","value":" 和 "},{"type":"inlineMath","value":"B"},{"type":"text","value":" 的最长公共子序列指 "},{"type":"inlineMath","value":"A"},{"type":"text","value":" 和 "},{"type":"inlineMath","value":"B"},{"type":"text","value":" 的所有公共子序列中元素个数最多的那些。"}]},{"type":"heading","depth":2,"children":[{"type":"text","value":"算法一"}],"identifier":"heading-算法一"},{"type":"paragraph","children":[{"type":"text","value":"记 "},{"type":"inlineMath","value":"dp(i,j)"},{"type":"text","value":" 表示 "},{"type":"inlineMath","value":"\\lbrace a_1, a_2, \\cdots, a_i \\rbrace"},{"type":"text","value":" 和\n"},{"type":"inlineMath","value":"\\lbrace b_1, b_2, \\cdots, b_j \\rbrace"},{"type":"text","value":" 的最长上升子序列长度，不难发现转移方程为："}]},{"type":"math","value":"dp(i,j) = dp(i-1, j-1) + f(i, j), \\quad\\text{其中}\\; f(i,j) = \\left\\lbrace\\begin{aligned}&0, &i \\geqslant M \\;\\text{或}\\;  j \\geqslant N \\;\\text{或}\\; a_i \\neq a_j\\\\&1, &i < M \\;\\text{且}\\;  j < N \\;\\text{且}\\; a_i=a_j \\end{aligned}\\right."},{"type":"heading","depth":2,"children":[{"type":"text","value":"算法二"}],"identifier":"heading-算法二"},{"type":"paragraph","children":[{"type":"text","value":"此算法仅当 "},{"type":"inlineMath","value":"A"},{"type":"text","value":" 或 "},{"type":"inlineMath","value":"B"},{"type":"text","value":" 中 "},{"type":"emphasis","children":[{"type":"strong","children":[{"type":"text","value":"不存在重复元素时"}]}]},{"type":"text","value":"有效，为方便表述，不妨记 "},{"type":"inlineMath","value":"A"},{"type":"text","value":" 中不存在重复元素。则算法过程如下："}]},{"type":"list","ordered":false,"marker":42,"spread":true,"children":[{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"通过排序的方式，获得一个 "},{"type":"inlineMath","value":"idx"},{"type":"text","value":" 数组，其中 "},{"type":"inlineMath","value":"idx(i)"},{"type":"text","value":" 表示 "},{"type":"inlineMath","value":"a_{idx(i)}"},{"type":"text","value":"\n为 "},{"type":"inlineMath","value":"A"},{"type":"text","value":" 中第 "},{"type":"inlineMath","value":"i+1"},{"type":"text","value":" 小的元素。此部分时间复杂度为："},{"type":"inlineMath","value":"O(M\\log M)"}]},{"type":"code","lang":"typescript","meta":"title=\"lcs-2-1.ts\" {8}","value":"export function calcRankIdx(a: number[]): number[] {\n  const _size = a.length\n  if (_size <= 0) return [0, []]\n  if (_size === 1) return [1, [1]]\n\n  const idx: number[] = new Array(_size)\n  for (let i = 0; i < _size; ++i) idx[i] = i\n  idx.sort((x, y) => a[x] - a[y])\n  return idx\n}\n"}]},{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"利用上面得到的 "},{"type":"inlineCode","value":"idx"},{"type":"text","value":" 函数，即可通过二分查找在 "},{"type":"inlineMath","value":"O(N\\log M)"},{"type":"text","value":" 的复杂度内求出\n"},{"type":"inlineMath","value":"b_j"},{"type":"text","value":" 是否在 "},{"type":"inlineMath","value":"a_j"},{"type":"text","value":" 中存在，且其对应的 "},{"type":"inlineMath","value":"j"},{"type":"text","value":" 是什么。"}]},{"type":"code","lang":"typescript","meta":"title=\"lcs-2-1.ts\" {5,6}","value":"const idx = calcRankIdx(a)\nconst c: number[] = []\nfor (let i=0; i < N; ++i) {\n  const x = b[i]\n  const j = lowerBound(0, N, k => x < a[idx[k]])\n  if (j < N && a[idx[j]] === x) c.push(idx[j])\n}\n"}]},{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"之后再对 "},{"type":"inlineMath","value":"c"},{"type":"text","value":" 求一次最长上升子序列即可，复杂度为 "},{"type":"inlineMath","value":"O(N\\log N)"},{"type":"text","value":"，故总复杂度为："}]},{"type":"list","ordered":false,"marker":45,"spread":false,"children":[{"type":"listItem","children":[{"type":"text","value":"时间复杂度："},{"type":"inlineMath","value":"O(M\\log M + N\\log M + M\\log M)"}]},{"type":"listItem","children":[{"type":"text","value":"空间复杂度为："},{"type":"inlineMath","value":"O(M+N)"}]}]}]}]},{"type":"heading","depth":2,"children":[{"type":"text","value":"Related"}],"identifier":"heading-related"},{"type":"list","ordered":false,"marker":42,"spread":false,"children":[{"type":"listItem","children":[{"type":"link","url":"../LIS","children":[{"type":"text","value":"最长公共子序列（LIS） | guanghechen"}]}]}]}]},"definitionMap":{},"footnoteDefinitionMap":{},"fields":{"slug":"/quiz/algorithm/LCS/"}},"previous":{"title":"最长上升子序列（LIS）","fields":{"slug":"/quiz/algorithm/LIS/"}},"next":{"title":"扔鸡蛋问题","fields":{"slug":"/quiz/algorithm/dp/egg-drop/"}},"postItems":{"nodes":[{"title":"最长公共子序列（LCS）","createAt":"2021-06-02","tags":["quiz","最长公共子序列","LCS"],"fields":{"slug":"/quiz/algorithm/LCS/"}},{"title":"最长上升子序列（LIS）","createAt":"2021-06-02","tags":["quiz","最长上升子序列","LIS"],"fields":{"slug":"/quiz/algorithm/LIS/"}},{"title":"不修改数组找出重复的数字","createAt":"2021-06-29","tags":["quiz","分治","追击"],"fields":{"slug":"/quiz/algorithm/partition/find-duplicate-number/"}},{"title":"统计区间内的线段","createAt":"2021-07-21","tags":["quiz","扫描线","前缀和","树状数组","线段树"],"fields":{"slug":"/quiz/algorithm/scanning-line/segments/"}},{"title":"约瑟夫环问题","createAt":"2021-07-16","tags":["quiz","经典问题","约瑟夫环"],"fields":{"slug":"/quiz/classical/Josephus-ring/"}},{"title":"扔鸡蛋问题","createAt":"2021-06-20","tags":["quiz","动态规划"],"fields":{"slug":"/quiz/algorithm/dp/egg-drop/"}}]}},"pageContext":{"id":"fef3d8fa-711e-55b2-bd1f-5ebe19b3bebe","contentType":"quiz","paginationUrl":"/quizzes","previousPostId":"881e8006-8e3e-54b3-b850-e657094c1a1e","nextPostId":"bb38555c-3fdf-57dc-a3f6-06abdde53ab0"}},"staticQueryHashes":["1005149165","1639449909"]}